{
  "name": "mfme-cli",
  "version": "0.1.0",
  "private": false,
  "description": "Unofficial CLI for Moneyforward ME (UI automation via Playwright)",
  "bin": {
    "mfme": "./src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "start": "bun run src/cli.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "install-browsers": "bun x playwright install chromium"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260427.1",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
